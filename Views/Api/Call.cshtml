@model ApiEndpoint
@{
    ViewData["Title"] = $"Call {Model.Method} {Model.Path}";
    var isGet = Model.Method == "GET";
}

<div class="form-page" style="max-width:700px">
    <a asp-action="Details" asp-route-id="@Model.ApiId" class="back-link">← Back to @Model.Api.Name</a>
    <h1 class="page-title">
        <span class="method-badge method-@Model.Method.ToLower()">@Model.Method</span>
        @Model.Path
    </h1>
    <p class="muted">@Model.Description</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }

    <form method="post" class="api-form">
        @Html.AntiForgeryToken()

        <h2 class="section-title">Headers</h2>

        <div class="form-group">
            <label>ClientID</label>
            <input name="clientId" class="form-control" placeholder="CLIENT-001" />
        </div>

        <div class="form-group">
            <label>ClientName</label>
            <input name="clientName" class="form-control" placeholder="PremierBankingApp" />
        </div>

        @if (!isGet)
        {
            <h2 class="section-title">Request Body</h2>

            @if (Model.Path.Contains("fetchCardDetails"))
            {
                <p class="muted" style="margin-bottom:0.75rem">Enter the card number to look up:</p>
                <div class="form-group">
                    <label>Card Number</label>
                    <input id="cardNumberInput" class="form-control" placeholder="4111111111111111" maxlength="16" />
                </div>
                <input type="hidden" name="requestBody" id="requestBody" />
                <script>
                    document.querySelector('form').addEventListener('submit', function () {
                        var card = document.getElementById('cardNumberInput').value;
                        document.getElementById('requestBody').value = JSON.stringify({ cardNumber: card });
                    });
                </script>
            }
            else if (Model.Path.Contains("retrieveAccount"))
            {
                <p class="muted" style="margin-bottom:0.75rem">Enter the account ID to look up:</p>
                <div class="form-group">
                    <label>Account ID</label>
                    <input id="accountIdInput" class="form-control" placeholder="ACC-00123" />
                </div>
                <input type="hidden" name="requestBody" id="requestBody" />
                <script>
                    document.querySelector('form').addEventListener('submit', function () {
                        var acc = document.getElementById('accountIdInput').value;
                        document.getElementById('requestBody').value = JSON.stringify({ accountID: acc });
                    });
                </script>
            }
            else if (Model.Path.Contains("updateCardStatus"))
            {
                <p class="muted" style="margin-bottom:0.75rem">Update a card's status:</p>
                <div class="form-group">
                    <label>Card Number</label>
                    <input id="cardNum" class="form-control" placeholder="4111111111111111" />
                </div>
                <div class="form-group">
                    <label>New Status</label>
                    <select id="cardStatus" class="form-control">
                        <option value="ACTIVE">ACTIVE</option>
                        <option value="BLOCKED">BLOCKED</option>
                    </select>
                </div>
                <input type="hidden" name="requestBody" id="requestBody" />
                <script>
                    document.querySelector('form').addEventListener('submit', function () {
                        document.getElementById('requestBody').value = JSON.stringify({
                            cardNumber: document.getElementById('cardNum').value,
                            newStatus: document.getElementById('cardStatus').value
                        });
                    });
                </script>
            }
            else
            {
                <div class="form-group">
                    <label>Request Body (JSON)</label>
                    <textarea name="requestBody" class="form-control" rows="6" placeholder='{ "key": "value" }'></textarea>
                </div>
            }
        }
        else
        {
            <input type="hidden" name="requestBody" value="" />
        }

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Send Request</button>
        </div>
    </form>

    @if (ViewBag.Response != null)
    {
        <div class="response-box">
            <div class="response-header">
                <span class="response-title">Response</span>
                <span class="status-badge @(ViewBag.IsSuccess ? "status-up" : "status-down")">
                    HTTP @ViewBag.StatusCode
                </span>
            </div>
            <pre class="response-body">@ViewBag.Response</pre>
        </div>
    }
</div>
